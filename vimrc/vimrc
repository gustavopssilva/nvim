" ============================================================================
" Autocompletion automática (popup enquanto digita) — sem plugin
" ============================================================================
" Usa <C-n> nativo (palavras do buffer + outros buffers carregados).
" Limitação: completa por prefixo, sem fuzzy; sem método de classe Java.
" Pra desligar no boot:    let g:auto_popup = 0  (antes do autocmd carregar)
" Pra desligar na sessão:  :let g:auto_popup = 0
let g:auto_popup = get(g:, 'auto_popup', 1)

" menuone: mostra popup mesmo com 1 match. noinsert/noselect: não escolhe sozinho.
set completeopt=menuone,noinsert,noselect
set shortmess+=c
set pumheight=5           " máximo de 5 itens visíveis no popup (scroll no resto)

augroup AutoCompletePopup
  autocmd!
  autocmd InsertCharPre * call s:AutoComplete()
augroup END

function! s:AutoComplete() abort
  if !g:auto_popup | return | endif
  if pumvisible() | return | endif
  " Só dispara quando o char atual e o anterior são 'palavra'
  " (evita popup ruidoso em espaço, símbolo ou início de palavra)
  if v:char =~ '\k' && getline('.')[col('.')-2] =~ '\k'
    call feedkeys("\<C-n>", 'n')
  endif
endfunction

" Tab/S-Tab navegam o popup; <C-y> aceita (Enter fica livre pros iabbrev)
inoremap <expr> <Tab>   pumvisible() ? "\<C-n>" : "\<Tab>"
inoremap <expr> <S-Tab> pumvisible() ? "\<C-p>" : "\<S-Tab>"

" ============================================================================
" Funções de Formatação Segura (não apaga código se houver erro)
" ============================================================================
function! SafeFormat(cmd, success_msg)
  let l:view = winsaveview()
  let l:tmpfile = tempname() . '.' . expand('%:e')
  call writefile(getline(1, '$'), l:tmpfile)
  
  " npm_config_loglevel=warn reduz a sujeira do npx no terminal
  let l:real_cmd = "env npm_config_yes=true npm_config_loglevel=warn " . substitute(a:cmd, '%', l:tmpfile, 'g') . " 2>&1"
  let l:output = system(l:real_cmd)
  
  if v:shell_error == 0
    execute "normal! gg\"_dG"
    call setline(1, split(l:output, "\n"))
    redraw | echo "✨ " . a:success_msg
  else
    let l:err_lines = split(l:output, "\n")
    let l:short_err = len(l:err_lines) > 0 ? l:err_lines[0] : "Erro desconhecido"
    let l:short_err = substitute(l:short_err, '^.\{-}:', 'Linha ', '')
    redraw | echohl ErrorMsg | echo "❌ " . l:short_err | echohl None
  endif
  
  call delete(l:tmpfile)
  call winrestview(l:view)
endfunction


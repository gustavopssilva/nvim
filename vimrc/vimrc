" ============================================================================
" .vimrc minimalista — zero plugins, foco em dev/análise em VM remota
" Linguagens: Java, SQL, JS, Markdown, HTML, JSON
" ============================================================================
"
" SETUP VM NOVA:
"   1. Instala os pacotes abaixo.
"   2. Copia o seu .vimrc para a Home.
"   3. Abre o projeto Java na raiz e digita :Ctags uma vez.
"   4. Pronto. Tudo funcionará exatamente como está agora.
"
" 1. Instalar pacotes:
"    Ubuntu: sudo apt update && sudo apt install -y vim-gtk3 universal-ctags ripgrep jq pgformatter
"    Fedora: sudo dnf install -y vim universal-ctags ripgrep jq
" 2. Gerar tags (GoTo): No Vim, dentro da raiz do projeto, digite :Ctags
" 3. Clipboard: Requer vim-gtk3 e conexao via 'ssh -X'
"
"  Se quiser instalar o Java (Necessário para o formatador):
"   sudo apt update && sudo apt install -y openjdk-17-jdk

"  Se quiser Instalar Node.js (Opcional, se quiser o fallback do npx):
"     sudo apt install -y nodejs npm
" FORMATADOR JAVA: 
"   O seu .vimrc já está configurado para tentar usar o google-java-format via npx (Node.js).
" Se a VM não tiver Node, você pode baixar o JAR manualmente com o comando que deixamos no topo do seu .vimrc.
" Tenta via npx automaticamente. Para instalar o JAR fixo (se nao tiver Node):
" mkdir -p ~/.vim/tools && curl -L -o ~/.vim/tools/google-java-format.jar https://github.com/google/google-java-format/releases/download/v1.22.0/google-java-format-1.22.0-all-deps.jar
"
" FORMATADOR SQL:
" sudo curl -o /usr/local/bin/pg_format https://raw.githubusercontent.com/darold/pgFormatter/master/pg_format && sudo chmod +x /usr/local/bin/pg_format
" ============================================================================

" ============================================================================
" Opções básicas
" ============================================================================
set nocompatible
syntax on
filetype plugin indent on

let mapleader = " "

" Sessões / números / scroll
set sessionoptions=blank,buffers,curdir,folds,help,tabpages,winsize,winpos,terminal,localoptions
set relativenumber
set number
set scrolloff=10
set cursorline
set hidden                " permite trocar de buffer sem salvar; essencial para Netrw
set shortmess+=atI        " Silencia mensagens de 'pressione enter' e introdução
set lazyredraw            " Melhora performance e evita flickers em scripts
set noshowmode            " Não mostra '-- INSERT --' (já está na statusline)

" Indentação
set tabstop=2
set shiftwidth=2
set softtabstop=2
set expandtab
set smarttab
set autoindent

" Busca
set ignorecase
set smartcase
set incsearch
set hlsearch
set wildignorecase        " Ignora maiúsculas/minúsculas na busca de arquivos (:find)

" UI
set nowrap                " sem quebra (markdown sobrescreve)
set termguicolors
set background=dark
set signcolumn=auto
set showcmd
set laststatus=2
set splitright
set splitbelow
set mouse=a
set autoread

" Edição
set backspace=indent,eol,start
set clipboard=unnamedplus  " Integração com clipboard do sistema
set nobackup
set nowritebackup
set noswapfile

" Iskeyword inclui _ e -
set iskeyword+=_
set iskeyword+=-

" Folding por syntax (vim não tem treesitter)
set foldmethod=syntax
set foldlevel=20
set foldlevelstart=99
set foldenable

" :find busca recursivo a partir do cwd
set path=.,**

" Wildmenu com fuzzy (Vim 9+); em vim 8 cai no prefix-match silenciosamente
set wildmenu
set wildmode=longest:full,full
silent! set wildoptions=pum,fuzzy
set wildignore+=*/node_modules/*,*/target/*,*/build/*,*/dist/*,*/.git/*,*.class,*.jar,*.swp,*.zip,*.tar.gz,tags

" :grep usa ripgrep se existir
if executable('rg')
  set grepprg=rg\ --vimgrep\ --smart-case\ --hidden\ --glob=!.git\ --glob=!tags
  set grepformat=%f:%l:%c:%m
endif

" Tags geradas por ctags (rode `ctags -R` na raiz do projeto)
set tags=./tags;,tags;

" ============================================================================
" Tema
" ============================================================================
" retrobox parece com gruvbox e vem no Vim 9.1+; fallback pra habamax (9.0+)
" e slate (built-in antigo).
silent! colorscheme retrobox
if !exists('g:colors_name') || g:colors_name == ''
  silent! colorscheme habamax
endif
if !exists('g:colors_name') || g:colors_name == ''
  silent! colorscheme slate
endif

" Highlight da palavra com */# (não pula pra próxima ocorrência)
nnoremap <silent> * :let @/='\V\<'.escape(expand('<cword>'), '/\').'\>'<CR>:set hlsearch<CR>
nnoremap <silent> # :let @/='\V\<'.escape(expand('<cword>'), '/\').'\>'<CR>:set hlsearch<CR>
nnoremap <silent> <Esc><Esc> :nohlsearch<CR>


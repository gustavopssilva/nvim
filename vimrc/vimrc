augroup END

" --- CSS --------------------------------------------------------------------
augroup ft_css
  autocmd!
  autocmd FileType css setlocal omnifunc=csscomplete#CompleteCSS
augroup END

" --- JSON -------------------------------------------------------------------
augroup ft_json
  autocmd!
  autocmd FileType json nnoremap <buffer> <leader>gf :call SafeFormat("jq . %", "JSON formatado")<CR>
augroup END


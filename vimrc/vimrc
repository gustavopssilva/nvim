" ============================================================================
" Harpoon Minimalista (estilo Neovim, sem plugins)
" ============================================================================
let g:harpoon_files = []

function! HarpoonAdd()
  let l:file = expand('%:p')
  if index(g:harpoon_files, l:file) == -1
    call add(g:harpoon_files, l:file)
    echo "📌 Adicionado ao Harpoon: " . expand('%:t')
  endif
endfunction

function! HarpoonShow()
  let l:display = []
  let l:i = 1
  for f in g:harpoon_files
    call add(l:display, l:i . ": " . fnamemodify(f, ':t'))
    let l:i += 1
  endfor
  let l:choice = inputlist(['--- HARPOON ---'] + l:display)
  if l:choice > 0 && l:choice <= len(g:harpoon_files)
    execute 'edit ' . g:harpoon_files[l:choice-1]
  endif
endfunction

function! HarpoonNav(idx)
  if a:idx <= len(g:harpoon_files)
    execute 'edit ' . g:harpoon_files[a:idx-1]
  endif
endfunction

nnoremap <leader>ha :call HarpoonAdd()<CR>
nnoremap <leader>hh :call HarpoonShow()<CR>
nnoremap <leader>h1 :call HarpoonNav(1)<CR>
nnoremap <leader>h2 :call HarpoonNav(2)<CR>
nnoremap <leader>h3 :call HarpoonNav(3)<CR>
nnoremap <leader>h4 :call HarpoonNav(4)<CR>

" ============================================================================
" Comentários nativos (gcc e gc) - Sem plugins
" ============================================================================
function! ToggleComment() range
  let l:cms = split(&commentstring, '%s')
  let l:pre = substitute(l:cms[0], '^\s*\|\s*$', '', 'g')
  let l:suf = len(l:cms) > 1 ? substitute(l:cms[1], '^\s*\|\s*$', '', 'g') : ""
  
  " Verifica se a primeira linha do range já está comentada
  let l:is_commented = getline(a:firstline) =~ '^\s*' . escape(l:pre, '*/')

  if l:is_commented
    " Descomentar
    let l:pattern = '^\(\s*\)' . escape(l:pre, '*/') . '\s*\(.*\)' . (l:suf != "" ? '\s*' . escape(l:suf, '*/') : "") . '\s*$'
    execute a:firstline . ',' . a:lastline . 's#' . l:pattern . '#\1\2#e'
  else
    " Comentar
    let l:pattern = '^\(\s*\)\(.*\)$'
    let l:replace = '\1' . l:pre . ' \2' . (l:suf != "" ? " " . l:suf : "")
    execute a:firstline . ',' . a:lastline . 's#' . l:pattern . '#' . l:replace . '#e'
  endif
endfunction

nnoremap <silent> gcc :call ToggleComment()<CR>
vnoremap <silent> gc :call ToggleComment()<CR>

